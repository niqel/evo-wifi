title: "WiFi UML Component Diagram: Contracts, Providers, Resolvers, and Agent Subject"
direction: right

vars: {
  contract-fill: "#eef6ff"
  provider-fill: "#ddf4ff"
  candidate-fill: "#fff8c5"
  resolver-fill: "#f6f8fa"
  external-fill: "#f6f8fa"
  root-fill: "#e6ffed"
  agent-fill: "#ddf4ff"
  stroke: "#59636e"
}

input_contracts: {
  label: "Input Contracts"
  style.stroke: ${stroke}

  action_selection: {
    label: "<<contract / trait>>\nWifiActionSelectionInputContract"
    style.fill: ${contract-fill}
  }
  network_selection: {
    label: "<<contract / trait>>\nWifiNetworkSelectionInputContract"
    style.fill: ${contract-fill}
  }
  password: {
    label: "<<contract / trait>>\nWifiPasswordInputContract"
    style.fill: ${contract-fill}
  }
}

output_contracts: {
  label: "Output Contracts"
  style.stroke: ${stroke}

  network: {
    label: "<<contract / trait>>\nWifiNetworkOutputContract"
    style.fill: ${contract-fill}
  }
  status: {
    label: "<<contract / trait>>\nWifiStatusOutputContract"
    style.fill: ${contract-fill}
  }
  secret: {
    label: "<<contract / trait>>\nWifiSecretOutputContract"
    style.fill: ${contract-fill}
  }
  message: {
    label: "<<contract / trait>>\nWifiMessageOutputContract"
    style.fill: ${contract-fill}
  }
}

wifi_contracts: {
  label: "WiFi Contracts"
  style.stroke: ${stroke}

  scan: {
    label: "<<contract / trait>>\nWifiScanContract"
    style.fill: ${contract-fill}
  }
  interface: {
    label: "<<contract / trait>>\nWifiInterfaceContract"
    style.fill: ${contract-fill}
  }
  status: {
    label: "<<contract / trait>>\nWifiStatusContract"
    style.fill: ${contract-fill}
  }
  connect: {
    label: "<<contract / trait>>\nWifiConnectContract"
    style.fill: ${contract-fill}
  }
  saved_network: {
    label: "<<contract / trait>>\nWifiSavedNetworkContract"
    style.fill: ${contract-fill}
  }
  saved_secret: {
    label: "<<contract / trait>>\nWifiSavedSecretContract"
    style.fill: ${contract-fill}
  }
  forget: {
    label: "<<contract / trait>>\nWifiForgetContract"
    style.fill: ${contract-fill}
  }
}

runtime_assembly: {
  label: "Runtime Assembly"
  style.stroke: ${stroke}

  composition_root: {
    label: "<<composition root>>\nEvoWifiCompositionRoot\n\ncreates providers\ninvokes agent_subject\nno use-case logic"
    style.fill: ${root-fill}
  }
}

contract_function_rule: {
  label: "Contract function rule\n\ncontracts expose: provide\nresolvers expose: resolve\nproviders implement: provide"
  style.fill: "#ffffff"
  style.stroke: ${stroke}
}

agents: {
  label: "Agents"
  style.stroke: ${stroke}

  wifi_connection_status_shower: {
    label: "<<agent_subject>>\nagents::wifi_connection_status_shower::show"
    style.fill: ${agent-fill}
  }
}

resolvers: {
  label: "Resolvers"
  style.stroke: ${stroke}

  wifi_interface: {
    label: "<<resolver>>\nwifi_interface_resolver::resolve"
    style.fill: ${resolver-fill}
  }
  wifi_connection_status: {
    label: "<<resolver>>\nwifi_connection_status_resolver::resolve"
    style.fill: ${resolver-fill}
  }
  wifi_connection_status_output: {
    label: "<<resolver>>\nwifi_connection_status_output_resolver::resolve"
    style.fill: ${resolver-fill}
  }
}

input_providers: {
  label: "Input Providers"
  style.stroke: ${stroke}

  terminal: {
    label: "<<provider>>\nTerminalInputProvider"
    style.fill: ${provider-fill}
  }
  tui: {
    label: "<<provider candidate>>\nTuiInputProvider"
    style.fill: ${candidate-fill}
  }
  web: {
    label: "<<provider candidate>>\nWebInputProvider"
    style.fill: ${candidate-fill}
  }
}

output_providers: {
  label: "Output Providers"
  style.stroke: ${stroke}

  terminal: {
    label: "<<provider>>\nTerminalOutputProvider"
    style.fill: ${provider-fill}
  }
  tui: {
    label: "<<provider candidate>>\nTuiOutputProvider"
    style.fill: ${candidate-fill}
  }
  web: {
    label: "<<provider candidate>>\nWebOutputProvider"
    style.fill: ${candidate-fill}
  }
}

wifi_providers: {
  label: "WiFi Providers"
  style.stroke: ${stroke}

  void: {
    label: "<<provider>>\nVoidWifiProvider\n\nuses:\n- wpa_supplicant / wpa_cli\n- dhcpcd\n- iw / ip\n- runit / sv"
    style.fill: ${provider-fill}
  }
  windows: {
    label: "<<provider candidate>>\nWindowsWifiProvider"
    style.fill: ${candidate-fill}
  }
  network_manager: {
    label: "<<provider candidate>>\nNetworkManagerWifiProvider"
    style.fill: ${candidate-fill}
  }
  iwd: {
    label: "<<provider candidate>>\nIwdWifiProvider"
    style.fill: ${candidate-fill}
  }
}

void_external_components: {
  label: "Void External Components"
  style.stroke: ${stroke}

  wpa_supplicant: {
    label: "<<external service>>\nwpa_supplicant"
    style.fill: ${external-fill}
  }
  wpa_cli: {
    label: "<<external command>>\nwpa_cli"
    style.fill: ${external-fill}
  }
  dhcpcd: {
    label: "<<external service / command>>\ndhcpcd"
    style.fill: ${external-fill}
  }
  iw: {
    label: "<<external command>>\niw"
    style.fill: ${external-fill}
  }
  ip: {
    label: "<<external command>>\nip"
    style.fill: ${external-fill}
  }
  sv: {
    label: "<<external command>>\nsv"
    style.fill: ${external-fill}
  }
  runit: {
    label: "<<external service manager>>\nrunit"
    style.fill: ${external-fill}
  }
}

runtime_assembly.composition_root -> wifi_providers.void: creates
runtime_assembly.composition_root -> input_providers.terminal: creates
runtime_assembly.composition_root -> output_providers.terminal: creates
runtime_assembly.composition_root -> agents.wifi_connection_status_shower: invokes
runtime_assembly.composition_root -> contract_function_rule: follows {
  style.stroke-dash: 4
}

input_providers.terminal -> input_contracts.action_selection: implements
input_providers.terminal -> input_contracts.network_selection: implements
input_providers.terminal -> input_contracts.password: implements

output_providers.terminal -> output_contracts.network: implements
output_providers.terminal -> output_contracts.status: implements
output_providers.terminal -> output_contracts.secret: implements
output_providers.terminal -> output_contracts.message: implements

input_providers.tui -> input_contracts.action_selection: may implement {
  style.stroke-dash: 4
}
input_providers.web -> input_contracts.action_selection: may implement {
  style.stroke-dash: 4
}
output_providers.tui -> output_contracts.status: may implement {
  style.stroke-dash: 4
}
output_providers.web -> output_contracts.status: may implement {
  style.stroke-dash: 4
}

wifi_providers.void -> wifi_contracts.scan: implements
wifi_providers.void -> wifi_contracts.interface: implements
wifi_providers.void -> wifi_contracts.status: implements
wifi_providers.void -> wifi_contracts.connect: implements
wifi_providers.void -> wifi_contracts.saved_network: implements
wifi_providers.void -> wifi_contracts.saved_secret: implements
wifi_providers.void -> wifi_contracts.forget: implements

wifi_providers.windows -> wifi_contracts.scan: may implement {
  style.stroke-dash: 4
}
wifi_providers.network_manager -> wifi_contracts.scan: may implement {
  style.stroke-dash: 4
}
wifi_providers.iwd -> wifi_contracts.scan: may implement {
  style.stroke-dash: 4
}

wifi_providers.void -> void_external_components.wpa_cli: uses
wifi_providers.void -> void_external_components.dhcpcd: uses
wifi_providers.void -> void_external_components.iw: uses
wifi_providers.void -> void_external_components.ip: uses
wifi_providers.void -> void_external_components.sv: uses

void_external_components.wpa_cli -> void_external_components.wpa_supplicant: controls
void_external_components.sv -> void_external_components.runit: talks to
void_external_components.sv -> void_external_components.wpa_supplicant: manages {
  style.stroke-dash: 4
}
void_external_components.sv -> void_external_components.dhcpcd: manages {
  style.stroke-dash: 4
}

agents.wifi_connection_status_shower -> resolvers.wifi_interface: "pipeline step 1"
resolvers.wifi_interface -> resolvers.wifi_connection_status: "WifiInterfaceBorrowed<'a>"
resolvers.wifi_connection_status -> resolvers.wifi_connection_status_output: "WifiConnectionStatusBorrowed<'a>"

resolvers.wifi_interface -> wifi_contracts.interface: uses {
  style.stroke-dash: 4
}
resolvers.wifi_connection_status -> wifi_contracts.status: uses {
  style.stroke-dash: 4
}
resolvers.wifi_connection_status_output -> output_contracts.status: uses {
  style.stroke-dash: 4
}
