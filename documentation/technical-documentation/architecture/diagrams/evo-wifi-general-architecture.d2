title: "evo-wifi General Architecture"
direction: right

vars: {
  border: "#59636e"
  accent: "#0D32B2"
  soft: "#eef6ff"
  neutral: "#f6f8fa"
  white: "#ffffff"
}

agent: {
  label: "agent\n(case-use coordinator)"
  style.fill: ${soft}
  style.stroke: ${accent}
}

resolver: {
  label: "resolver\n(resolve)"
  style.fill: ${white}
  style.stroke: ${accent}
}

contracts: {
  label: "contracts\n(expected behavior)"
  style.fill: ${white}
  style.stroke: ${accent}
}

providers: {
  label: "providers\nsingle responsibility\nprovide()"
  style.fill: ${white}
  style.stroke: ${border}
}

external: {
  label: "external world\nterminal / WiFi / OS"
  style.fill: ${neutral}
  style.stroke: ${border}
}

domain: {
  label: "domain forms"
  style.fill: ${neutral}
  style.stroke: ${border}

  borrowed: {
    label: "borrowed\nlightweight views"
    style.fill: ${white}
    style.stroke: ${border}
  }
}

agent -> resolver: "chains"
resolver -> contracts: "depends on"
contracts -> providers: "implemented by"
providers -> external: "talks to"
resolver -> domain.borrowed: "operates on"
