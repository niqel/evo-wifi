title: "WiFi UML Component Diagram: Contracts, Providers, Resolvers, and Agent Subject"
direction: right

vars: {
  contract-fill: "#eef6ff"
  provider-fill: "#ddf4ff"
  candidate-fill: "#fff8c5"
  resolver-fill: "#f6f8fa"
  external-fill: "#f6f8fa"
  root-fill: "#e6ffed"
  agent-fill: "#ddf4ff"
  stroke: "#59636e"
}

input_contracts: {
  label: "Input Contracts"
  style.stroke: ${stroke}

  action_selection: {
    label: "<<contract / trait>>\nWifiActionSelectionInputContract"
    style.fill: ${contract-fill}
  }
  network_selection: {
    label: "<<contract / trait>>\nWifiNetworkSelectionInputContract"
    style.fill: ${contract-fill}
  }
  password: {
    label: "<<contract / trait>>\nWifiPasswordInputContract"
    style.fill: ${contract-fill}
  }
  status: {
    label: "<<contract / trait>>\nWifiStatusContract"
    style.fill: ${contract-fill}
  }
  scan: {
    label: "<<contract / trait>>\nWifiScanContract"
    style.fill: ${contract-fill}
  }
  interface: {
    label: "<<contract / trait>>\nWifiInterfaceContract"
    style.fill: ${contract-fill}
  }
  saved_network: {
    label: "<<contract / trait>>\nWifiSavedNetworkContract"
    style.fill: ${contract-fill}
  }
  saved_secret: {
    label: "<<contract / trait>>\nWifiSavedSecretContract"
    style.fill: ${contract-fill}
  }
}

output_contracts: {
  label: "Output Contracts"
  style.stroke: ${stroke}

  network: {
    label: "<<contract / trait>>\nWifiNetworkOutputContract"
    style.fill: ${contract-fill}
  }
  status: {
    label: "<<contract / trait>>\nWifiStatusOutputContract"
    style.fill: ${contract-fill}
  }
  secret: {
    label: "<<contract / trait>>\nWifiSecretOutputContract"
    style.fill: ${contract-fill}
  }
  message: {
    label: "<<contract / trait>>\nWifiMessageOutputContract"
    style.fill: ${contract-fill}
  }
}

action_contracts: {
  label: "Action Contracts"
  style.stroke: ${stroke}

  connect: {
    label: "<<contract / trait>>\nWifiConnectContract"
    style.fill: ${contract-fill}
  }
  new_connect: {
    label: "<<contract / trait>>\nWifiNewNetworkConnectContract"
    style.fill: ${contract-fill}
  }
  disconnect: {
    label: "<<contract / trait>>\nWifiDisconnectContract"
    style.fill: ${contract-fill}
  }
  forget: {
    label: "<<contract / trait>>\nWifiForgetContract"
    style.fill: ${contract-fill}
  }
}

runtime_assembly: {
  label: "Runtime Assembly"
  style.stroke: ${stroke}

  command_assembly: {
    label: "<<runtime wiring>>\nmain.rs + commands\n\nselect action\ncreate providers\ninvoke agents"
    style.fill: ${root-fill}
  }
}

contract_function_rule: {
  label: "Contract function rule\n\ncontracts expose: provide\nresolvers expose: resolve\nproviders implement: provide"
  style.fill: "#ffffff"
  style.stroke: ${stroke}
}

agents: {
  label: "Agents"
  style.stroke: ${stroke}

  wifi_connection_status_shower: {
    label: "<<agent_subject>>\nagents::wifi_connection_status_shower::show"
    style.fill: ${agent-fill}
  }

  wifi_network_switcher: {
    label: "<<agent_subject>>\nagents::wifi_network_switcher::switch"
    style.fill: ${agent-fill}
  }
}

resolvers: {
  label: "Resolvers"
  style.stroke: ${stroke}

  wifi_interface: {
    label: "<<resolver>>\nwifi_interface_resolver::resolve"
    style.fill: ${resolver-fill}
  }
  wifi_connection_status: {
    label: "<<resolver>>\nwifi_connection_status_resolver::resolve"
    style.fill: ${resolver-fill}
  }
  wifi_network_switch: {
    label: "<<resolver>>\nwifi_network_switch_resolver::resolve\n\nroutes:\n- already connected\n- saved network connect\n- password fallback\n- new connect"
    style.fill: ${resolver-fill}
  }
  wifi_connection_status_output: {
    label: "<<resolver>>\nwifi_connection_status_output_resolver::resolve"
    style.fill: ${resolver-fill}
  }
}

input_providers: {
  label: "Input Providers"
  style.stroke: ${stroke}

  terminal_action_selection: {
    label: "<<provider>>\nTerminalActionSelectionInputProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  terminal_network_selection: {
    label: "<<provider>>\nTerminalNetworkSelectionInputProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  terminal_password: {
    label: "<<provider>>\nTerminalPasswordInputProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  void_scan: {
    label: "<<provider>>\nLinuxWpaWifiScanProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  void_interface: {
    label: "<<provider>>\nLinuxWpaWifiInterfaceProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  void_status: {
    label: "<<provider>>\nLinuxWpaWifiStatusProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  void_saved_network: {
    label: "<<provider>>\nLinuxWpaWifiSavedNetworkProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  void_saved_secret: {
    label: "<<provider>>\nLinuxWpaWifiSavedSecretProvider\nprovide()"
    style.fill: ${provider-fill}
  }
}

output_providers: {
  label: "Output Providers"
  style.stroke: ${stroke}

  terminal_network: {
    label: "<<provider>>\nTerminalNetworkOutputProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  terminal_status: {
    label: "<<provider>>\nTerminalStatusOutputProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  terminal_secret: {
    label: "<<provider>>\nTerminalSecretOutputProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  terminal_message: {
    label: "<<provider>>\nTerminalMessageOutputProvider\nprovide()"
    style.fill: ${provider-fill}
  }
}

action_providers: {
  label: "Action Providers"
  style.stroke: ${stroke}

  void_connect: {
    label: "<<provider>>\nLinuxWpaWifiConnectProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  void_new_connect: {
    label: "<<provider>>\nLinuxWpaWifiNewNetworkConnectProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  void_disconnect: {
    label: "<<provider>>\nLinuxWpaWifiDisconnectProvider\nprovide()"
    style.fill: ${provider-fill}
  }
  void_forget: {
    label: "<<provider>>\nLinuxWpaWifiForgetProvider\nprovide()"
    style.fill: ${provider-fill}
  }
}

void_external_components: {
  label: "Linux WPA External Components"
  style.stroke: ${stroke}

  wpa_supplicant: {
    label: "<<external service>>\nwpa_supplicant"
    style.fill: ${external-fill}
  }
  wpa_cli: {
    label: "<<external command>>\nwpa_cli"
    style.fill: ${external-fill}
  }
  dhcpcd: {
    label: "<<external service / command>>\ndhcpcd"
    style.fill: ${external-fill}
  }
  iw: {
    label: "<<external command>>\niw"
    style.fill: ${external-fill}
  }
  ip: {
    label: "<<external command>>\nip"
    style.fill: ${external-fill}
  }
  sv: {
    label: "<<external command>>\nsv"
    style.fill: ${external-fill}
  }
  runit: {
    label: "<<external service manager>>\nrunit"
    style.fill: ${external-fill}
  }
}

runtime_assembly.command_assembly -> input_providers.void_interface: creates
runtime_assembly.command_assembly -> input_providers.void_status: creates
runtime_assembly.command_assembly -> action_providers.void_connect: creates
runtime_assembly.command_assembly -> action_providers.void_new_connect: creates
runtime_assembly.command_assembly -> input_providers.terminal_network_selection: creates
runtime_assembly.command_assembly -> input_providers.terminal_password: creates
runtime_assembly.command_assembly -> output_providers.terminal_status: creates
runtime_assembly.command_assembly -> output_providers.terminal_message: creates
runtime_assembly.command_assembly -> agents.wifi_connection_status_shower: invokes
runtime_assembly.command_assembly -> agents.wifi_network_switcher: invokes
runtime_assembly.command_assembly -> contract_function_rule: follows {
  style.stroke-dash: 4
}

input_providers.terminal_action_selection -> input_contracts.action_selection: implements
input_providers.terminal_network_selection -> input_contracts.network_selection: implements
input_providers.terminal_password -> input_contracts.password: implements

output_providers.terminal_network -> output_contracts.network: implements
output_providers.terminal_status -> output_contracts.status: implements
output_providers.terminal_secret -> output_contracts.secret: implements
output_providers.terminal_message -> output_contracts.message: implements

input_providers.void_scan -> input_contracts.scan: implements
input_providers.void_interface -> input_contracts.interface: implements
input_providers.void_status -> input_contracts.status: implements
input_providers.void_saved_network -> input_contracts.saved_network: implements
input_providers.void_saved_secret -> input_contracts.saved_secret: implements
action_providers.void_connect -> action_contracts.connect: implements
action_providers.void_new_connect -> action_contracts.new_connect: implements
action_providers.void_disconnect -> action_contracts.disconnect: implements
action_providers.void_forget -> action_contracts.forget: implements

input_providers.void_scan -> void_external_components.wpa_cli: uses
input_providers.void_interface -> void_external_components.wpa_cli: uses
input_providers.void_interface -> void_external_components.iw: uses
input_providers.void_status -> void_external_components.wpa_cli: uses
action_providers.void_connect -> void_external_components.wpa_cli: uses
action_providers.void_connect -> void_external_components.dhcpcd: uses
action_providers.void_new_connect -> void_external_components.wpa_cli: uses
action_providers.void_new_connect -> void_external_components.dhcpcd: uses
input_providers.void_saved_network -> void_external_components.wpa_cli: uses
input_providers.void_saved_secret -> void_external_components.wpa_cli: uses
action_providers.void_disconnect -> void_external_components.wpa_cli: uses
action_providers.void_forget -> void_external_components.wpa_cli: uses

void_external_components.wpa_cli -> void_external_components.wpa_supplicant: controls
void_external_components.sv -> void_external_components.runit: talks to
void_external_components.sv -> void_external_components.wpa_supplicant: manages {
  style.stroke-dash: 4
}
void_external_components.sv -> void_external_components.dhcpcd: manages {
  style.stroke-dash: 4
}

agents.wifi_connection_status_shower -> resolvers.wifi_interface: "resolver chain"
agents.wifi_network_switcher -> resolvers.wifi_interface: "resolver chain"
agents.wifi_network_switcher -> resolvers.wifi_network_switch: "resolver chain"
resolvers.wifi_interface -> resolvers.wifi_connection_status: "WifiInterfaceBorrowed<'a>"
resolvers.wifi_network_switch -> resolvers.wifi_connection_status: "WifiConnectionStatusBorrowed<'a>"
resolvers.wifi_connection_status -> resolvers.wifi_connection_status_output: "WifiConnectionStatusBorrowed<'a>"

resolvers.wifi_interface -> input_contracts.interface: uses {
  style.stroke-dash: 4
}
resolvers.wifi_network_switch -> input_contracts.interface: uses {
  style.stroke-dash: 4
}
resolvers.wifi_connection_status -> input_contracts.status: uses {
  style.stroke-dash: 4
}
resolvers.wifi_network_switch -> input_contracts.status: uses {
  style.stroke-dash: 4
}
resolvers.wifi_network_switch -> action_contracts.connect: uses {
  style.stroke-dash: 4
}
resolvers.wifi_network_switch -> action_contracts.new_connect: uses {
  style.stroke-dash: 4
}
resolvers.wifi_network_switch -> input_contracts.saved_network: uses {
  style.stroke-dash: 4
}
resolvers.wifi_network_switch -> input_contracts.saved_secret: uses {
  style.stroke-dash: 4
}
resolvers.wifi_connection_status_output -> output_contracts.status: uses {
  style.stroke-dash: 4
}
